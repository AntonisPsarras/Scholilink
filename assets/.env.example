# Copy this file to assets/.env and fill in values from the Firebase console
# (Project settings → Your apps). Never commit assets/.env.

# --- Runtime mode ---
# Preferred toggle is: flutter run --dart-define=USE_LOCAL_EMULATORS=true
# This .env value is a fallback if no --dart-define is provided.
USE_LOCAL_EMULATORS=false

# Optional emulator overrides (defaults are auto-detected per platform).
# FIREBASE_EMULATOR_HOST=127.0.0.1
# FIREBASE_AUTH_EMULATOR_PORT=9099
# FIRESTORE_EMULATOR_PORT=8080
# FIREBASE_FUNCTIONS_EMULATOR_PORT=5001
# FIREBASE_STORAGE_EMULATOR_PORT=9199

# --- Core project (all platforms) ---
# For LOCAL emulator demo, copy assets/.env.demo — its FIREBASE_PROJECT_ID matches the Emulator hub (.firebaserc).
# If this id does not match the project used when you ran seed:local, demo logins will fail.
FIREBASE_PROJECT_ID=YOUR_PROJECT_ID
FIREBASE_MESSAGING_SENDER_ID=YOUR_SENDER_ID
# Use the bucket from Firebase Console → Storage (often PROJECT_ID.firebasestorage.app).
FIREBASE_STORAGE_BUCKET=YOUR_PROJECT_ID.firebasestorage.app

# --- Web ---
FIREBASE_WEB_API_KEY=YOUR_WEB_API_KEY
FIREBASE_WEB_APP_ID=1:000000000000:web:0000000000000000000000

# --- Android ---
FIREBASE_ANDROID_API_KEY=YOUR_ANDROID_API_KEY
FIREBASE_ANDROID_APP_ID=1:000000000000:android:0000000000000000000000

# --- iOS / macOS (bundle id must match Xcode / Runner) ---
FIREBASE_IOS_API_KEY=YOUR_IOS_API_KEY
FIREBASE_IOS_APP_ID=1:000000000000:ios:0000000000000000000000
FIREBASE_MACOS_APP_ID=1:000000000000:ios:0000000000000000000000
FIREBASE_IOS_BUNDLE_ID=com.example.student_dashboard

# --- Windows (Flutter desktop; often a second "Web" app in Firebase) ---
FIREBASE_WINDOWS_APP_ID=1:000000000000:web:0000000000000000000000

# --- Google Sign-In (OAuth client ID for your app) ---
GOOGLE_CLIENT_ID=000000000000-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
