# Pre-filled demo values for the Functions emulator.
# The Start-Demo script copies this to functions/.env automatically.
# LOCAL_DEMO_MODE=true bypasses all real AI/email calls — no API keys needed.

GOOGLE_AI_API_KEY=demo-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
LOCAL_DEMO_MODE=true

# Optional integrations (not required in demo mode)
TAVILY_API_KEY=demo-tavily-key

# EmailJS fallback for emulator (real secrets live in Secret Manager for prod)
EMAILJS_SERVICE_ID=demo_service_id
EMAILJS_TEMPLATE_ID=demo_template_id
EMAILJS_PUBLIC_KEY=demo_public_key
EMAILJS_PRIVATE_KEY=demo_private_key

# Timezone for daily Spark quota reset
SPARK_RESET_TIMEZONE=Europe/Athens
