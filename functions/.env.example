# ─── Local Emulator (functions/.env) ──────────────────────────────────────────
# Copy this file to functions/.env for local emulator development.
# For demo mode (no real API keys needed), copy functions/.env.demo instead.

# Optional fallbacks when secrets are not bound (emulator / LOCAL_DEMO_MODE).
# Production deploy uses Secret Manager via defineSecret() — do not rely on these alone.
GOOGLE_AI_API_KEY=YOUR_GOOGLE_AI_API_KEY
GEMINI_MODEL=gemini-2.5-flash
LOCAL_DEMO_MODE=false

# Optional: enables web-augmented exam quiz generation
# TAVILY_API_KEY=your_tavily_key_here

# Optional: fallback EmailJS values for emulator consent flow testing
# (plain EMAILJS_* keys; do not collide with production PARENT_CONSENT_EMAILJS_* secrets)
# EMAILJS_SERVICE_ID=your_service_id
# EMAILJS_TEMPLATE_ID=your_template_id
# EMAILJS_PUBLIC_KEY=your_public_key
# EMAILJS_PRIVATE_KEY=your_private_key

# Optional: IANA timezone for daily Spark quota reset
# SPARK_RESET_TIMEZONE=Europe/Athens

# Required for the parental consent email link (no hardcoded fallback in code).
# Set to the URL of your Firebase Hosting consent page (or any HTTPS URL you control).
# PARENT_CONSENT_BASE_URL=https://YOUR_PROJECT_ID.web.app/consent.html
# APP_DEEP_LINK_SCHEME=your_app_scheme


# ─── Production (Secret Manager — required for firebase deploy) ────────────────
# Secret names are bound in code via defineSecret(). Set once with the Firebase CLI:
#
#   firebase functions:secrets:set GOOGLE_AI_API_KEY
#   firebase functions:secrets:set TAVILY_API_KEY
#   firebase functions:secrets:set PARENT_CONSENT_EMAILJS_SERVICE_ID
#   firebase functions:secrets:set PARENT_CONSENT_EMAILJS_TEMPLATE_ID
#   firebase functions:secrets:set PARENT_CONSENT_EMAILJS_PUBLIC_KEY
#   firebase functions:secrets:set PARENT_CONSENT_EMAILJS_PRIVATE_KEY
#   firebase functions:secrets:set PRO_ACTIVATION_EMAILJS_SERVICE_ID
#   firebase functions:secrets:set PRO_ACTIVATION_EMAILJS_TEMPLATE_ID
#   firebase functions:secrets:set PRO_ACTIVATION_EMAILJS_PUBLIC_KEY
#   firebase functions:secrets:set PRO_ACTIVATION_EMAILJS_PRIVATE_KEY
#   firebase functions:secrets:set PRO_ACTIVATION_CODE_PEPPER
#   firebase deploy --only functions
#
# GOOGLE_AI_API_KEY: https://aistudio.google.com/apikey (enable Generative Language API).
# TAVILY_API_KEY: optional; exam quiz web context is skipped when empty.
#
# LOCAL_DEMO_MODE=true (with emulators) uses deterministic demo keys when secrets/env are unset.
# Avoid defining the same name as both a plain .env var and a secret on Cloud Run.
